<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Dessert Story - Premium Food Ordering</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(135deg,#0f172a,#1e293b);
    color:white;
}

/* HEADER */
header{
    padding:20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
}

.logo{
    font-size:22px;
    font-weight:700;
    color:#fbbf24;
}

/* HERO */
.hero{
    text-align:center;
    padding:60px 20px;
}

.hero h1{
    font-size:40px;
    color:#fff;
}

.hero p{
    margin-top:10px;
    color:#cbd5e1;
}

/* BUTTON */
.btn{
    display:inline-block;
    margin-top:20px;
    padding:12px 25px;
    background:#f59e0b;
    color:black;
    border-radius:30px;
    text-decoration:none;
    font-weight:600;
    transition:0.3s;
}

.btn:hover{
    background:#fbbf24;
    transform:scale(1.05);
}

/* MENU */
.section{
    padding:40px 20px;
}

.section h2{
    margin-bottom:20px;
    color:#fbbf24;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:rgba(255,255,255,0.08);
    border-radius:20px;
    padding:15px;
    backdrop-filter: blur(10px);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card img{
    width:100%;
    height:160px;
    object-fit:cover;
    border-radius:15px;
}

.price{
    color:#22c55e;
    font-weight:600;
    margin-top:5px;
}

/* FOOTER */
footer{
    text-align:center;
    padding:20px;
    background:rgba(255,255,255,0.05);
    margin-top:40px;
}

/* LOGIN MODAL */
.modal{
    display:none;
    position:fixed;
    top:0;left:0;
    width:100%;height:100%;
    background:rgba(0,0,0,0.7);
    justify-content:center;
    align-items:center;
}

.modal-content{
    background:white;
    color:black;
    padding:20px;
    border-radius:15px;
    width:300px;
    text-align:center;
}

input{
    width:100%;
    padding:10px;
    margin:10px 0;
}
</style>
</head>

<body>

<header>
    <div class="logo">🍰 The Dessert Story</div>
    <a class="btn" href="https://wa.me/917416135888?text=Hi%20I%20want%20to%20order%20food" target="_blank">Order on WhatsApp</a>
</header>

<section class="hero">
    <h1>Authentic Indian Food & Desserts</h1>
    <p>Veg | Non-Veg | Traditional Snacks | Homemade Pickles | AI Special Creations</p>
    <a class="btn" onclick="openLogin()">Login to Order</a>
</section>

<!-- VEG -->
<section class="section">
    <h2>🌱 Veg Items</h2>
    <div class="grid">

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?paneer" />
            <h3>Paneer Butter Masala</h3>
            <p class="price">₹180</p>
        </div>

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?biryani,veg" />
            <h3>Veg Biryani</h3>
            <p class="price">₹150</p>
        </div>

    </div>
</section>

<!-- NON VEG -->
<section class="section">
    <h2>🍗 Non-Veg Items</h2>
    <div class="grid">

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?chicken,biryani" />
            <h3>Chicken Biryani</h3>
            <p class="price">₹220</p>
        </div>

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?mutton,curry" />
            <h3>Mutton Curry</h3>
            <p class="price">₹320</p>
        </div>

    </div>
</section>

<!-- PICKLES AI STYLE -->
<section class="section">
    <h2>🥒 Traditional Pickles (AI Style Showcase)</h2>
    <div class="grid">

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?mango,pickle" />
            <h3>Avakaya Mango Pickle</h3>
            <p class="price">₹120</p>
        </div>

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?chilli,pickle" />
            <h3>Red Chilli Pickle</h3>
            <p class="price">₹130</p>
        </div>

    </div>
</section>

<!-- SNACKS -->
<section class="section">
    <h2>🍿 Indian Traditional Snacks</h2>
    <div class="grid">

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?samosa" />
            <h3>Samosa</h3>
            <p class="price">₹20</p>
        </div>

        <div class="card">
            <img src="https://source.unsplash.com/400x300/?pakora" />
            <h3>Pakoda</h3>
            <p class="price">₹30</p>
        </div>

    </div>
</section>

<!-- LOCATION -->
<section class="section">
    <h2>📍 Location</h2>
    <p>We deliver all over your city. Visit or order online.</p>
</section>

<!-- FOOTER -->
<footer>
    <p>© 2026 The Dessert Story | Call: 7416135888 | WhatsApp Order Available</p>
</footer>

<!-- LOGIN MODAL -->
<div class="modal" id="loginModal">
    <div class="modal-content">
        <h3>Login</h3>
        <input type="text" placeholder="Enter Name">
        <input type="text" placeholder="Phone Number">
        <button class="btn" onclick="closeLogin()">Continue</button>
    </div>
</div>

<script>
function openLogin(){
    document.getElementById("loginModal").style.display="flex";
}

function closeLogin(){
    document.getElementById("loginModal").style.display="none";
}
</script>

</body>
</html>
